// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id           String      @id @default(cuid())
  name         String
  imageUrl     String?     
  offerwall    String
  targetValue  Float
  currentValue Float       @default(0)
  deadline     DateTime
  status       String      @default("In Progress")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  milestones   Milestone[] 
}

model Milestone {
  id          String   @id @default(cuid())
  description String   
  reward      Float    
  isClaimed   Boolean  @default(false)
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model CatalogOffer {
  id          String   @id @default(cuid())
  gameName    String   
  imageUrl    String?  
  category    String   @default("Games") 
  offerwall   String   
  rawCoins    Int      
  usdValue    Float    
  requirement String   
  isHighest   Boolean  @default(false) 
  createdAt   DateTime @default(now())

  milestones  CatalogMilestone[]
}

model CatalogMilestone {
  id             String       @id @default(cuid())
  description    String       
  reward         Float        
  
  catalogOfferId String
  catalogOffer   CatalogOffer @relation(fields: [catalogOfferId], references: [id], onDelete: Cascade)
}