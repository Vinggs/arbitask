// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------
// 1. MODEL BAWAAN NEXTAUTH 
// -------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // ✅ TAMBAHAN BARU: Untuk halaman profil
  phone         String?   
  password      String?   
  
  accounts      Account[]
  sessions      Session[]
  
  // Relasi
  tasks         Task[]    
  notifications Notification[] // Relasi ke tabel Inbox baru
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------------------------------------
// 2. MODEL APLIKASI
// -------------------------------------------------
model Task {
  id           String      @id @default(cuid())
  name         String
  imageUrl     String?
  offerwall    String
  targetValue  Float
  currentValue Float       @default(0)
  deadline     DateTime
  status       String      @default("In Progress")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  // Sambungin Task ke User
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  milestones   Milestone[] 
}

model Milestone {
  id          String   @id @default(cuid())
  description String   
  reward      Float    
  isClaimed   Boolean  @default(false)
  evidenceUrl String?
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model CatalogOffer {
  id          String   @id @default(cuid())
  gameName    String   
  imageUrl    String?
  category    String   @default("Games") 
  platform    String   // ✅ TAMBAHAN: Buat misahin Swagbucks, Freecash, dll
  offerwall   String   // Tetap ada: Buat misahin Torox, RevU, dll
  rawCoins    Int      
  usdValue    Float    
  requirement String   
  isHighest   Boolean  @default(false) 
  createdAt   DateTime @default(now())

  milestones  CatalogMilestone[]
}

model CatalogMilestone {
  id             String       @id @default(cuid())
  description    String       
  reward         Float        
  
  catalogOfferId String
  catalogOffer   CatalogOffer @relation(fields: [catalogOfferId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------
// 3. FITUR BARU: INBOX / NOTIFICATION
// -------------------------------------------------
model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("SYSTEM") // Contoh: "SYSTEM", "TASK_UPDATE", "ACHIEVEMENT"
  isRead      Boolean  @default(false)    // Buat fitur "Mark as read"
  createdAt   DateTime @default(now())
  
  // Sambungin pesan ke User yang login
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}